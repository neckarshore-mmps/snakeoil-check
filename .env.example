# Snake-Oil-or-Gold Check — Environment Variables Template
# Copy to .env.local for local dev. Production reads from Vercel project env.
# NEVER paste literal secrets into this file. Use the pipe-pattern (per AD-33).

# --- Database (Phase 1) ---
# Pooled (default for app code, e.g., Drizzle queries from Next.js)
DATABASE_URL=
# Direct/unpooled (for migrations, drizzle-kit, scripts)
POSTGRES_URL_NON_POOLING=

# --- AI (Phase 2) ---
# Anthropic key — production reads from Vercel-env injected through AI Gateway.
# Local dev: populate via pipe-pattern (per AD-33), e.g.:
#   security find-generic-password -a "$USER" -s anthropic_api_key_tools -w
# NEVER paste literal keys here.
ANTHROPIC_API_KEY=

# Google AI key — required for Gemini Flash Free-Shot tier (Tier-1, provider=google).
# Local dev: populate via pipe-pattern, e.g.:
#   security find-generic-password -a "$USER" -s google_ai_api_key -w
# In Vercel production: injected via AI Gateway (VERCEL_OIDC_TOKEN handles routing).
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Plugin-Signal Router (Phase 2-A) ---
# Controls which AI provider + model each tier uses.
# Note: gateway-vs-byok routing is decided per-request via decidePath(byok_config)
# in src/lib/router/path.ts — NOT via a global ROUTER_MODE env flag.

# Tier-1 (Haiku-equivalent, fast + cheap): provider/model string
# Default: anthropic/claude-haiku-4-5  (€1 approx. per check)
ROUTER_TIER1_PROVIDER=anthropic
ROUTER_TIER1_MODEL=claude-haiku-4-5

# Tier-2 (Sonnet-equivalent, higher quality): provider/model string
# Default: anthropic/claude-sonnet-4-5  (€3 approx. per check)
ROUTER_TIER2_PROVIDER=anthropic
ROUTER_TIER2_MODEL=claude-sonnet-4-5

# Free-Shot tier: Google Gemini Flash (no Anthropic cost)
# Default: google/gemini-2.0-flash  (€0 until Google quota exhausted)
ROUTER_FREESHOT_PROVIDER=google
ROUTER_FREESHOT_MODEL=gemini-2.0-flash

# Token budgets are hardcoded in src/lib/router/budget.ts (TOKEN_BUDGETS const).
# Override-via-env is not yet implemented — see backlog if needed.

# --- AI Gateway (auto-injected in Vercel runtime, leave blank locally) ---
# VERCEL_OIDC_TOKEN is injected by Vercel and routes provider-strings
# through the AI Gateway. Locally, calls go direct to the provider via
# ANTHROPIC_API_KEY above. Listing for documentation only — do not set manually.
# VERCEL_OIDC_TOKEN=

# --- Anti-Abuse (Phase 2-B1) ---
# Cloudflare Turnstile — bot gate (Layer 1). Secret = server-side siteverify;
# site key = public, consumed by the client widget (frontend / Linus scope).
# Local dev: populate the secret via pipe-pattern (per AD-33), e.g.:
#   security find-generic-password -a "$USER" -s cloudflare_turnstile_secret -w
TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...   # public widget key (set by frontend)

# Upstash Redis (REST) — rate-limit (Layer 2), url-dedup (Layer 5), daily-quota
# (Layer 7) storage. Free tier is sufficient for MVP. Both Production + Preview.
#   security find-generic-password -a "$USER" -s upstash_redis_rest_url -w
#   security find-generic-password -a "$USER" -s upstash_redis_rest_token -w
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Pseudonymization key (GDPR F-NOW-1) — HMAC-SHA256 key for ALL identity
# hashes (IP, email, rate-limit keys). Rotatable: rolling it unlinks old
# digests; Redis keys derived from them expire via their TTLs. Required —
# identity hashing fails LOUD without it. Generate: openssl rand -hex 32
# Local dev: populate via pipe-pattern (per AD-33), e.g.:
#   security find-generic-password -a "$USER" -s snakeoil_hash_secret -w
HASH_SECRET=

# Cron auth (GDPR F-NOW-2) — bearer secret for /api/cron/purge-expired.
# Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}` automatically when
# set in the project env. Endpoint fails CLOSED (503) while unset.
# Generate: openssl rand -hex 32
CRON_SECRET=

# Kill-switch (Layer 6) — fail-closed/default-off: the Free-Shot funnel is in
# maintenance unless this is the exact string "true". MUST be set in Vercel
# before the funnel goes live in prod.
FREE_SHOT_ENABLED=false
# Daily system-wide Free-Shot cap (Layer 7) guarding provider free-tier
# exhaustion. Defaults to 50 if unset.
FREE_SHOT_DAILY_SYSTEM_LIMIT=50
